{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "System Initialization",
      "type": "shell",
      "command": "service docker start || true",
      "runOptions": { "runOn": "folderOpen" }
    },
    {
      "label": "Production Build",
      "type": "npm",
      "script": "build",
      "dependsOn": "System Initialization",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "runOptions": { "runOn": "folderOpen" }
    },
    {
      "label": "Runtime Execution",
      "type": "shell",
      "command": "node dist/index.js",
      "dependsOn": "Production Build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "runOptions": { "runOn": "folderOpen" }
    }
  ]
}
